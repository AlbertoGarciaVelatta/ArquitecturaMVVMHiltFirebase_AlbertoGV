<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText android:id="@+id/etNombre" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombre de la incidencia" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prioridad" android:layout_marginTop="8dp"/>
        <Spinner android:id="@+id/spinnerPrioridad" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Urgencia" android:layout_marginTop="8dp"/>
        <Spinner android:id="@+id/spinnerUrgencia" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Activo" android:layout_marginTop="8dp"/>
        <Spinner android:id="@+id/spinnerActivo" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Estado" android:layout_marginTop="8dp"/>
        <Spinner android:id="@+id/spinnerEstado" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <EditText android:id="@+id/etResponsable" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Responsable" android:layout_marginTop="8dp"/>

        <EditText android:id="@+id/etDescripcion" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Descripción" android:lines="3" android:layout_marginTop="8dp"/>

        <Button android:id="@+id/btnSeleccionarFoto" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Seleccionar Foto" android:layout_marginTop="16dp"/>

        <ImageView android:id="@+id/ivFotoPreview" android:layout_width="120dp" android:layout_height="120dp" android:layout_gravity="center" android:layout_marginTop="8dp" android:background="#E0E0E0"/>

        <Button android:id="@+id/btnGuardar" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Guardar Incidencia" android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>